# Loaded by docker-compose env_file. Real secrets.env must be chmod 600 root.
# Used by the taden-ot-ap profile (JDBC sidecar -> HHS001).
ORACLE_PASSWORD_ONPREM=replace-me
# Used by python-oracledb Thin example profiles (factory_a / factory_b / factory_legacy).
ORACLE_PASSWORD_A=replace-me
ORACLE_PASSWORD_B=replace-me
WALLET_PASSWORD_B=replace-me
ORACLE_PASSWORD_D=replace-me
# WiFi PSK for the taden-ot-ap profile. Read at runtime (as root) by the
# connect script Desktop/presence-tools/connect-taden-ot-ap.sh, NOT by the
# bridge container. Required, or connecting fails with "WIFI_PSK_TADEN
# が secrets.env にありません".
WIFI_PSK_TADEN=replace-me
